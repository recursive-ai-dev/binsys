# ═══════════════════════════════════════════════════════════════════════════
#  FrugalOS Kernel Configuration Fragment
#  Target  : x86_64, general hardware + VM
#  Applied : scripts/kconfig/merge_config.sh x86_64_defconfig frugalos.config
#  Tested  : Linux 6.6.x LTS (recommended)
#
#  Philosophy:
#    Everything the boot sequence CANNOT live without is built-in (=y).
#    Everything that loads AFTER pivot_root can be a module (=m) or plugin.
#    Anything unused is explicitly disabled to reduce attack surface + size.
#
#  Build after merging:
#    make -j$(nproc) bzImage
#    cp arch/x86/boot/bzImage /boot/vmlinuz
#
#  The resulting bzImage IS vmlinuz — no separate compression step needed.
#  Kernel self-decompresses to RAM on boot.
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# GENERAL
# ───────────────────────────────────────────────────────────────────────────

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y                        # multi-core; safe on single-core too
CONFIG_NR_CPUS=8                    # reasonable cap; raise for many-core
CONFIG_PREEMPT_NONE=y               # server/throughput model, not desktop
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set

CONFIG_HZ_250=y                     # 250 Hz tick — good balance
# CONFIG_HZ_100 is not set
# CONFIG_HZ_1000 is not set

CONFIG_MULTIUSER=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_FHANDLE=y

# Needed for busybox pivot_root
CONFIG_MULTIARCH_NATIVE=y

# ───────────────────────────────────────────────────────────────────────────
# MEMORY
# ───────────────────────────────────────────────────────────────────────────

CONFIG_SPARSEMEM_VMEMMAP=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
# CONFIG_TRANSPARENT_HUGEPAGE_MADVISE is not set
CONFIG_MEMORY_HOTPLUG=y             # needed for VM balloon drivers
CONFIG_SWAP=y

# ───────────────────────────────────────────────────────────────────────────
# FILESYSTEMS — ALL BOOT-CRITICAL ITEMS MUST BE =y, NOT =m
# ───────────────────────────────────────────────────────────────────────────

# SquashFS — MUST be built-in. The initrd mounts .sfs before any module
# loading infrastructure exists. A module here creates a chicken-and-egg
# deadlock: you need squashfs to mount the .sfs that contains the module.
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_FILE_CACHE=y
CONFIG_SQUASHFS_DECOMP_SINGLE=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y              # future-proof: zstd beats xz on speed

# OverlayFS — MUST be built-in. Same reason as squashfs.
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y    # enables dir rename across layers
CONFIG_OVERLAY_FS_REDIRECT_ALWAYS_FOLLOW=y
CONFIG_OVERLAY_FS_INDEX=y           # stable inode numbers across remounts
CONFIG_OVERLAY_FS_METACOPY=y        # copy-up metadata only, not data (fast)

# Loop devices — MUST be built-in. losetup runs before pivot_root.
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=16   # we may need up to ~16 SFS layers

# Tmpfs — MUST be built-in. /run, /tmp, overlay upper layer all use it.
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

# Proc and Sysfs — MUST be built-in.
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y

# devtmpfs — auto-populates /dev at boot without udev
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y             # kernel mounts it automatically

# EXT4 — boot device filesystem (FAT alt supported; ext4 preferred)
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_XATTR=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_JBD2=y

# FAT — EFI System Partition + USB sticks
CONFIG_FAT_FS=y
CONFIG_MSDOS_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="utf8"
CONFIG_FAT_DEFAULT_UTF8=y

# ISO9660 — optional, for live CD booting
CONFIG_ISO9660_FS=m
CONFIG_JOLIET=y
CONFIG_UDF_FS=m

# Additional useful filesystems (post-pivot, safe as modules)
CONFIG_FUSE_FS=m
CONFIG_CIFS=m
CONFIG_NFS_FS=m

# Disable filesystems we explicitly don't support
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_OCFS2_FS is not set
# CONFIG_GFS2_FS is not set
# CONFIG_NILFS2_FS is not set
# CONFIG_REISERFS_FS is not set
# CONFIG_JFS_FS is not set

# ───────────────────────────────────────────────────────────────────────────
# BLOCK DEVICES + STORAGE
# ───────────────────────────────────────────────────────────────────────────

# NVMe — built-in for modern bare-metal where this is the boot device
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y

# AHCI (SATA) — built-in for SATA boot drives
CONFIG_ATA=y
CONFIG_ATA_VERBOSE_ERROR=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y                   # PATA/legacy IDE compat

# VirtIO block — built-in for VM boot from virtio-blk disk
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_BLK=y

# USB Storage — built-in for USB boot sticks
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y               # USB 3.x
CONFIG_USB_EHCI_HCD=y               # USB 2.0
CONFIG_USB_UHCI_HCD=y               # USB 1.1 compat
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y                    # USB Attached SCSI (fast USB3 drives)

# MMC/SD — for embedded targets or SD-card boot
CONFIG_MMC=m
CONFIG_MMC_SDHCI=m
CONFIG_MMC_SDHCI_PCI=m

# ───────────────────────────────────────────────────────────────────────────
# NETWORKING — MINIMAL BASE; STACK IS A PLUGIN
# ───────────────────────────────────────────────────────────────────────────

CONFIG_NET=y
CONFIG_INET=y                       # IPv4 — needed even for loopback
CONFIG_IPV6=m
CONFIG_PACKET=y                     # raw sockets (dhcp, etc.)
CONFIG_UNIX=y                       # Unix domain sockets (IPC)
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y

# Ethernet — base support; specific NIC drivers are plugins
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=m
CONFIG_E1000E=m
CONFIG_IGB=m
CONFIG_IXGBE=m
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_R8169=m                      # covers most consumer Realtek NICs

# VirtIO networking — built-in so VMs have connectivity without plugins
CONFIG_VIRTIO_NET=y

# Disable wireless in base — it's a plugin (large dep tree, many drivers)
# CONFIG_WIRELESS is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set
# CONFIG_WLAN is not set

# ───────────────────────────────────────────────────────────────────────────
# EFI + BOOT
# ───────────────────────────────────────────────────────────────────────────

CONFIG_EFI=y
CONFIG_EFI_STUB=y                   # vmlinuz loads directly from EFI without GRUB
CONFIG_EFI_MIXED=y                  # 32-bit EFI with 64-bit kernel (rare but real)
CONFIG_DMI=y
CONFIG_ACPI=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_AC=m
CONFIG_ACPI_BATTERY=m
CONFIG_ACPI_BUTTON=m
CONFIG_ACPI_FAN=m
CONFIG_ACPI_THERMAL=m
CONFIG_X86_PM_TIMER=y
CONFIG_HIBERNATION=y
CONFIG_PM_SLEEP=y

# Bootloader protocol
# CONFIG_CMDLINE_BOOL is not set      # we pass cmdline from bootloader, not compiled in
CONFIG_PHYSICAL_ALIGN=0x200000

# ───────────────────────────────────────────────────────────────────────────
# CONSOLE + DISPLAY
# The base kernel needs at least one console for emergency shell output.
# GPU/KMS/DRM drivers are plugins (X11 or Wayland plugin pulls them in).
# ───────────────────────────────────────────────────────────────────────────

CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_DUMMY_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# VESA/EFI framebuffer — works on any EFI machine without a real GPU driver
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FB_VESA=y

# VirtIO GPU for VM console
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y

# Serial console — critical for headless / embedded targets
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4

# VirtIO console (VM serial)
CONFIG_VIRTIO_CONSOLE=y

# ───────────────────────────────────────────────────────────────────────────
# CHARACTER DEVICES
# ───────────────────────────────────────────────────────────────────────────

CONFIG_DEVPTS_MULTIPLE_INSTANCES=y  # needed for containers / namespaces
CONFIG_UNIX98_PTYS=y
CONFIG_LEGACY_PTYS=y
CONFIG_LEGACY_PTY_COUNT=32

CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# /dev/mem and /dev/kmem — keep for now, harden later
CONFIG_DEVMEM=y
# CONFIG_DEVKMEM is not set                   # rarely needed, security risk

# ───────────────────────────────────────────────────────────────────────────
# PROCESS / NAMESPACE / SECURITY
# ───────────────────────────────────────────────────────────────────────────

CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y

CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Minimal LSM — plugins can add more
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_DEFAULT_SECURITY_DAC=y

# CONFIG_SECURITY_SELINUX is not set          # plugin if needed
# CONFIG_SECURITY_APPARMOR is not set         # plugin if needed

# ───────────────────────────────────────────────────────────────────────────
# KERNEL DEBUGGING — OFF IN PRODUCTION
# Enable selectively during development by adding =y to specific options.
# ───────────────────────────────────────────────────────────────────────────

# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_KPROBES is not set
# CONFIG_FTRACE is not set
# CONFIG_KALLSYMS_ALL is not set
# CONFIG_MAGIC_SYSRQ is not set               # enable for dev, disable for prod

CONFIG_PRINTK=y                             # always keep boot messages
CONFIG_EARLY_PRINTK=y
CONFIG_LOG_BUF_SHIFT=17                     # 128KB ring buffer

# ───────────────────────────────────────────────────────────────────────────
# CRYPTO — MINIMAL; TLS/FULL CRYPTO IS A PLUGIN
# Enough for kernel integrity + DM-crypt if needed
# ───────────────────────────────────────────────────────────────────────────

CONFIG_CRYPTO=y
CONFIG_CRYPTO_AEAD=y
CONFIG_CRYPTO_HASH=y
CONFIG_CRYPTO_SKCIPHER=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y        # hardware AES on modern x86
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_MD5=y                 # legacy compat only

# ───────────────────────────────────────────────────────────────────────────
# MODULE INFRASTRUCTURE
# Modules are for hardware that loads after pivot_root (NICs, GPU, audio).
# ───────────────────────────────────────────────────────────────────────────

CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y        # allows plugin-ctl to clean up modules
CONFIG_MODULE_VERSIONING=y          # ABI versioning — prevents wrong-kernel modules
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SRCVERSION_ALL=y
# CONFIG_MODULE_SIG is not set      # enable if you want signed module enforcement

# ───────────────────────────────────────────────────────────────────────────
# EXPLICITLY DISABLED — keeps vmlinuz lean and attack surface minimal
# Re-enable by adding to a plugin's kernel module list or a separate
# kernel config overlay for specific hardware targets.
# ───────────────────────────────────────────────────────────────────────────

# CONFIG_SOUND is not set                     # audio plugin
# CONFIG_SND is not set
# CONFIG_BLUETOOTH is not set                 # bluetooth plugin
# CONFIG_INFINIBAND is not set                # HPC plugin
# CONFIG_ISDN is not set
# CONFIG_HAMRADIO is not set
# CONFIG_NFC is not set
# CONFIG_MEDIA_SUPPORT is not set             # webcam/tuner plugin
# CONFIG_DVB_CORE is not set
# CONFIG_STAGING is not set                   # staging drivers — never in production
# CONFIG_ANDROID is not set
# CONFIG_CHROME_PLATFORMS is not set          # unless building for Chromebook
# CONFIG_RAPIDIO is not set
# CONFIG_PCCARD is not set                    # PCMCIA — effectively dead on x86_64
