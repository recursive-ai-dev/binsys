#!/bin/sh
#═══════════════════════════════════════════════════════════════════════════════
#  /usr/bin/manifest-new — FrugalOS Plugin Scaffold Tool
#
#  Creates a ready-to-populate plugin directory with:
#    .plugin/manifest    — key=value metadata (ash-sourceable)
#    .plugin/on_load     — hook called after hot-load (executable)
#    .plugin/on_unload   — hook called before hot-unload (executable)
#    .plugin/modules     — kernel module list (optional, starts empty)
#    usr/bin/ usr/lib/ usr/share/ etc/  — standard FHS dirs to populate
#    README              — reminds you how to build
#
#  Usage:
#    manifest-new <name>                     interactive prompts
#    manifest-new <name> --batch [options]   non-interactive
#
#  Batch options (all optional, have defaults):
#    --version   <ver>          default: 1.0.0
#    --desc      <description>
#    --depends   "pkg1 pkg2"
#    --conflicts "pkg1"
#    --provides  "capability"
#    --order     <integer>      LOAD_ORDER, default: 50
#    --outdir    <path>         default: ./<name>
#
#  LOAD_ORDER ranges (enforced by convention, not code):
#    0         reserved: base (musl + busybox)
#    1–9       kernel modules, hardware drivers
#    10–19     core libraries (libc extras, libssl, libz)
#    20–39     graphics / audio / input stack
#    40–59     general applications (default range)
#    60–79     desktop environments, window managers
#    80–99     user preference layers, themes, dotfiles
#═══════════════════════════════════════════════════════════════════════════════

set -e
PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

#───────────────────────────────────────────────────────────────────────────────
# COLOUR
#───────────────────────────────────────────────────────────────────────────────

if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    C_GRN='\033[1;32m'; C_YEL='\033[1;33m'; C_BLU='\033[1;34m'
    C_WHT='\033[1;37m'; C_DIM='\033[0;37m'; C_RST='\033[0m'
else
    C_GRN=''; C_YEL=''; C_BLU=''; C_WHT=''; C_DIM=''; C_RST=''
fi

log()    { printf "${C_GRN}=>${C_RST} %s\n" "$*"; }
prompt() { printf "${C_BLU}  ?${C_RST} %s " "$*"; }
info()   { printf "  %s\n" "$*"; }
warn()   { printf "${C_YEL}  warn:${C_RST} %s\n" "$*" >&2; }
die()    { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }
ok()     { printf "${C_GRN}  ✓${C_RST} %s\n" "$*"; }

#───────────────────────────────────────────────────────────────────────────────
# VALIDATION
#───────────────────────────────────────────────────────────────────────────────

# Plugin name: lowercase, alphanumeric + hyphen, no leading hyphen
validate_name() {
    local name="$1"
    [ -n "$name" ] || { warn "name cannot be empty"; return 1; }
    case "$name" in
        -*)               warn "name cannot start with hyphen"; return 1 ;;
        *[!a-z0-9-_]*)   warn "name must be lowercase alphanumeric, hyphen, or underscore"; return 1 ;;
        base)             warn "'base' is reserved"; return 1 ;;
    esac
    [ "${#name}" -le 48 ] || { warn "name too long (max 48 chars)"; return 1; }
    return 0
}

# Version: digits and dots, e.g. 1.0.0 or 2024.06.24
validate_version() {
    local ver="$1"
    [ -n "$ver" ] || { warn "version cannot be empty"; return 1; }
    case "$ver" in
        *[!0-9.]*)  warn "version must contain only digits and dots"; return 1 ;;
        .*|*.)      warn "version cannot start or end with a dot"; return 1 ;;
    esac
    return 0
}

# LOAD_ORDER: integer 1–99
validate_order() {
    local order="$1"
    case "$order" in
        ''|*[!0-9]*) warn "LOAD_ORDER must be a positive integer"; return 1 ;;
    esac
    [ "$order" -ge 1 ] && [ "$order" -le 99 ] \
        || { warn "LOAD_ORDER must be between 1 and 99 (0 is reserved for base)"; return 1; }
    return 0
}

# Depends/conflicts: space-separated plugin names, each individually validated
validate_name_list() {
    local list="$1"
    [ -z "$list" ] && return 0
    for n in $list; do
        validate_name "$n" || return 1
    done
    return 0
}

#───────────────────────────────────────────────────────────────────────────────
# INTERACTIVE PROMPT WITH DEFAULT
# Usage: ask_with_default "question" "default_value"
# Reads into $REPLY
#───────────────────────────────────────────────────────────────────────────────

ask_with_default() {
    local question="$1"
    local default="$2"
    local display_default=""

    [ -n "$default" ] && display_default=" [${default}]"

    while true; do
        prompt "${question}${display_default}:"
        read -r REPLY
        REPLY="${REPLY:-$default}"
        [ -n "$REPLY" ] && return 0
        warn "required — please enter a value"
    done
}

ask_optional() {
    local question="$1"
    prompt "${question} (optional, press enter to skip):"
    read -r REPLY
}

#───────────────────────────────────────────────────────────────────────────────
# INTERACTIVE MODE
#───────────────────────────────────────────────────────────────────────────────

interactive_prompts() {
    printf '\n'
    printf "${C_WHT}  FrugalOS Plugin Scaffold${C_RST}\n"
    printf '  ─────────────────────────────────────────\n\n'

    # Name (already set from arg)
    info "Plugin name: ${C_WHT}${OPT_NAME}${C_RST}"
    printf '\n'

    # Version
    while true; do
        ask_with_default "Version" "1.0.0"
        OPT_VERSION="$REPLY"
        validate_version "$OPT_VERSION" && break
    done

    # Description
    ask_optional "Short description (one line)"
    OPT_DESC="$REPLY"

    # Depends
    while true; do
        ask_optional "Dependencies (space-separated plugin names)"
        OPT_DEPENDS="$REPLY"
        validate_name_list "$OPT_DEPENDS" && break
    done

    # Conflicts
    while true; do
        ask_optional "Conflicts (space-separated plugin names)"
        OPT_CONFLICTS="$REPLY"
        validate_name_list "$OPT_CONFLICTS" && break
    done

    # Provides
    ask_optional "Provides (capability tag, e.g. 'web-browser' or 'text-editor')"
    OPT_PROVIDES="$REPLY"

    # Load order with guidance
    printf '\n'
    info "LOAD_ORDER (1-99) controls stack position:"
    info "  1-9   kernel/hw  | 10-19 core libs  | 20-39 graphics"
    info "  40-59 apps       | 60-79 desktop     | 80-99 user layers"
    while true; do
        ask_with_default "Load order" "50"
        OPT_ORDER="$REPLY"
        validate_order "$OPT_ORDER" && break
    done

    printf '\n'
}

#───────────────────────────────────────────────────────────────────────────────
# WRITE PLUGIN SKELETON
#───────────────────────────────────────────────────────────────────────────────

write_skeleton() {
    local outdir="$1"

    [ -e "$outdir" ] && die "directory already exists: $outdir"
    mkdir -p "$outdir"

    # ── .plugin/ ────────────────────────────────────────────────────────────
    mkdir -p "${outdir}/.plugin"

    # manifest
    cat > "${outdir}/.plugin/manifest" <<EOF
# FrugalOS Plugin Manifest
# This file is sourced by busybox ash — use only key="value" syntax.
# No subshells, no backticks, no here-docs.

NAME="${OPT_NAME}"
VERSION="${OPT_VERSION}"
DESCRIPTION="${OPT_DESC}"
ARCH="x86_64"

# Space-separated list of plugin NAMEs that must be loaded before this one.
# Each dep must have a lower LOAD_ORDER than this plugin.
DEPENDS="${OPT_DEPENDS}"

# Space-separated list of plugin NAMEs that cannot coexist with this one.
CONFLICTS="${OPT_CONFLICTS}"

# Capability tag — used by other plugins to declare abstract deps.
# e.g. DEPENDS="web-browser" will match any plugin with PROVIDES="web-browser"
PROVIDES="${OPT_PROVIDES}"

# Integer 1-99. Lower = loaded first = lower in overlay stack.
# Higher-order plugins override lower-order ones for conflicting files.
# Reserved ranges:
#   0     base (do not use)
#   1-9   kernel modules, drivers
#   10-19 core libraries
#   20-39 graphics, audio, input
#   40-59 general applications  ← you are here (default)
#   60-79 desktop environments
#   80-99 user preference layers
LOAD_ORDER=${OPT_ORDER}

# Paths to hook scripts inside this .sfs (relative to /)
# Called by plugin-ctl after mounting / before dismounting.
HOOK_LOAD="/.plugin/on_load"
HOOK_UNLOAD="/.plugin/on_unload"
EOF

    # on_load hook
    cat > "${outdir}/.plugin/on_load" <<ONLOAD
#!/bin/sh
# /.plugin/on_load — called by plugin-ctl after hot-loading ${OPT_NAME}
# Environment: running as root on the live overlay root
# Working dir: /
# Return 0 on success, non-zero to signal a warning (load still completes)

# Example: start a background service
# /usr/bin/${OPT_NAME}d --daemonize

exit 0
ONLOAD

    # on_unload hook
    cat > "${outdir}/.plugin/on_unload" <<ONUNLOAD
#!/bin/sh
# /.plugin/on_unload — called by plugin-ctl before hot-unloading ${OPT_NAME}
# Stop services, flush state, release resources.
# Return 0 on success, non-zero to signal a warning (unload still continues).

# Example: stop a background service
# pkill -x ${OPT_NAME}d 2>/dev/null || true

exit 0
ONUNLOAD

    # modules list (empty — fill in if this plugin ships kernel modules)
    cat > "${outdir}/.plugin/modules" <<MODULES
# /.plugin/modules — kernel modules to load with this plugin
# One module name per line. Lines starting with # are ignored.
# These are passed to modprobe in order during load,
# and modprobe -r in reverse order during unload.
# Example:
#   v4l2
#   uvcvideo
MODULES

    chmod 755 "${outdir}/.plugin/on_load"
    chmod 755 "${outdir}/.plugin/on_unload"

    # ── FHS directories ─────────────────────────────────────────────────────
    # Plugins follow FHS — files go under usr/ or etc/ as appropriate.
    # Avoid /bin and /sbin directly; use /usr/bin and /usr/sbin.
    for d in \
        usr/bin \
        usr/sbin \
        usr/lib \
        usr/share/"${OPT_NAME}" \
        usr/share/man/man1 \
        etc/"${OPT_NAME}" \
        lib/modules
    do
        mkdir -p "${outdir}/${d}"
    done

    # ── boot/shutdown service hooks ─────────────────────────────────────────
    # If this plugin needs to start/stop services at boot, drop scripts here.
    mkdir -p "${outdir}/etc/frugalos/init.d/boot.d"
    mkdir -p "${outdir}/etc/frugalos/init.d/shutdown.d"

    cat > "${outdir}/etc/frugalos/init.d/boot.d/50-${OPT_NAME}.sh" <<BOOTSVC
#!/bin/sh
# Boot service hook for ${OPT_NAME}
# Called after sysinit, before gettys.
# Remove this file if your plugin has no boot-time service.

# Example:
# /usr/bin/${OPT_NAME}d --daemonize && echo "  [ok] ${OPT_NAME}"
BOOTSVC

    cat > "${outdir}/etc/frugalos/init.d/shutdown.d/50-${OPT_NAME}.sh" <<SHUTSVC
#!/bin/sh
# Shutdown hook for ${OPT_NAME}
# Called before unmounting filesystems.
# Remove this file if your plugin has no shutdown-time cleanup.

# Example:
# pkill -x ${OPT_NAME}d 2>/dev/null || true
SHUTSVC

    # ── README ──────────────────────────────────────────────────────────────
    cat > "${outdir}/README" <<README
# ${OPT_NAME} — FrugalOS Plugin

## Structure

    .plugin/
      manifest      Plugin metadata (edit this first)
      on_load       Runs after hot-load   (plugin-ctl load)
      on_unload     Runs before hot-unload (plugin-ctl unload)
      modules       Kernel modules to modprobe on load

    usr/bin/        Executables
    usr/lib/        Libraries
    usr/share/${OPT_NAME}/  Data files
    etc/${OPT_NAME}/        Config files

    etc/frugalos/init.d/boot.d/
                    Scripts run at boot (before getty)
    etc/frugalos/init.d/shutdown.d/
                    Scripts run at shutdown

## Populate

Put your files under this directory following FHS conventions.
Symlinks, empty directories, and zero-byte files are all fine in squashfs.

## Build

    plugin-ctl build ./${OPT_NAME} ${OPT_NAME}

This runs mksquashfs and deposits ${OPT_NAME}.sfs in:
    /mnt/boot/plugins/available/

## Activate

    plugin-ctl enable ${OPT_NAME}   # load at next boot
    plugin-ctl load   ${OPT_NAME}   # hot-load now
    plugin-ctl reload ${OPT_NAME}   # rebuild + reload (dev cycle)

## Verify

    plugin-ctl verify ${OPT_NAME}   # squashfs integrity check
    plugin-ctl info   ${OPT_NAME}   # show manifest + status
README

}

#───────────────────────────────────────────────────────────────────────────────
# ARGUMENT PARSING
#───────────────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF

${C_WHT}manifest-new${C_RST} — FrugalOS Plugin Scaffold Tool

${C_YEL}Usage:${C_RST}
  manifest-new <name>                    interactive
  manifest-new <name> --batch [options]  non-interactive

${C_YEL}Options:${C_RST}
  --version   <ver>       plugin version     (default: 1.0.0)
  --desc      <text>      short description
  --depends   "a b c"     space-separated deps
  --conflicts "x"         space-separated conflicts
  --provides  <tag>       capability tag
  --order     <1-99>      LOAD_ORDER         (default: 50)
  --outdir    <path>      output directory   (default: ./<name>)
  --batch                 skip interactive prompts

${C_YEL}LOAD_ORDER ranges:${C_RST}
  1-9   kernel/hw      10-19  core libs    20-39  graphics/audio
  40-59 apps (default) 60-79  desktop      80-99  user layers

EOF
    exit 1
}

# Defaults
OPT_NAME=""
OPT_VERSION="1.0.0"
OPT_DESC=""
OPT_DEPENDS=""
OPT_CONFLICTS=""
OPT_PROVIDES=""
OPT_ORDER="50"
OPT_OUTDIR=""
OPT_BATCH=0

[ $# -ge 1 ] || usage

OPT_NAME="$1"; shift

validate_name "$OPT_NAME" || die "invalid plugin name: $OPT_NAME"

while [ $# -gt 0 ]; do
    case "$1" in
        --version)   OPT_VERSION="$2";   shift 2 ;;
        --desc)      OPT_DESC="$2";      shift 2 ;;
        --depends)   OPT_DEPENDS="$2";   shift 2 ;;
        --conflicts) OPT_CONFLICTS="$2"; shift 2 ;;
        --provides)  OPT_PROVIDES="$2";  shift 2 ;;
        --order)     OPT_ORDER="$2";     shift 2 ;;
        --outdir)    OPT_OUTDIR="$2";    shift 2 ;;
        --batch)     OPT_BATCH=1;        shift   ;;
        --help|-h)   usage ;;
        *) die "unknown option: $1" ;;
    esac
done

[ -z "$OPT_OUTDIR" ] && OPT_OUTDIR="./${OPT_NAME}"

#───────────────────────────────────────────────────────────────────────────────
# MAIN
#───────────────────────────────────────────────────────────────────────────────

if [ "$OPT_BATCH" = "0" ]; then
    interactive_prompts
else
    # Batch mode — validate what was passed
    validate_version  "$OPT_VERSION"  || die "invalid --version"
    validate_order    "$OPT_ORDER"    || die "invalid --order"
    validate_name_list "$OPT_DEPENDS"  || die "invalid --depends"
    validate_name_list "$OPT_CONFLICTS" || die "invalid --conflicts"
fi

log "creating plugin skeleton: $OPT_OUTDIR"
write_skeleton "$OPT_OUTDIR"

printf '\n'
ok "plugin scaffold created: ${C_WHT}${OPT_OUTDIR}${C_RST}"
printf '\n'
info "Next steps:"
info "  1. Add your files to ${OPT_OUTDIR}/usr/bin/, ${OPT_OUTDIR}/usr/lib/, etc."
info "  2. Edit ${OPT_OUTDIR}/.plugin/manifest to confirm metadata"
info "  3. Edit hooks in ${OPT_OUTDIR}/.plugin/ if needed"
info "  4. plugin-ctl build ${OPT_OUTDIR} ${OPT_NAME}"
printf '\n'
