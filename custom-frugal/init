#!/bin/sh
#═══════════════════════════════════════════════════════════════════════════════
#  /init — FrugalOS Initrd Init Script
#  Architecture : x86_64
#  Runtime      : busybox ash (no bash-isms)
#  Filesystem   : SquashFS layers stacked via OverlayFS
#═══════════════════════════════════════════════════════════════════════════════

set -eu
PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

#───────────────────────────────────────────────────────────────────────────────
# GLOBAL STATE
#───────────────────────────────────────────────────────────────────────────────

BOOT_LABEL="FRUGALOS"
BOOT_UUID=""
BOOT_DEV=""
SAVE_DIR="save"
INIT_BIN="/sbin/init"
DEBUG=0

BOOT_MOUNT="/mnt/boot"
LAYERS_BASE="/mnt/layers"
NEWROOT="/newroot"

PLUGIN_STATE_DIR="/run/plugin-state"
PLUGIN_LOOPS_DIR="/run/plugin-loops"

UPPER_DIR=""
WORK_DIR=""

_MOUNTPOINTS_FILE="/run/_init_mountpoints"
_LOOP_RECORDS_FILE="/run/_init_loop_records"
_ORDERED_SFS_FILE="/run/_init_ordered_sfs"

#───────────────────────────────────────────────────────────────────────────────
# LOGGING
#───────────────────────────────────────────────────────────────────────────────

log()  { printf '  \033[1;32m[init]\033[0m %s\n' "$*"; }
dbg()  { [ "$DEBUG" = "1" ] && printf '  \033[0;36m[dbg] \033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m[warn]\033[0m %s\n' "$*" >&2; }

die() {
    printf '\n  \033[1;31mFATAL BOOT ERROR: %s\033[0m\n' "$*"
    printf '  Dropping to emergency shell. Type "exit" to retry boot.\n\n'
    exec /bin/sh
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 0 — EARLY MOUNTS
#───────────────────────────────────────────────────────────────────────────────

stage0_early_mounts() {
    log "Stage 0: early mounts"

    mount -t proc     proc     /proc     2>/dev/null || die "cannot mount /proc"
    mount -t sysfs    sysfs    /sys      2>/dev/null || die "cannot mount /sys"
    mount -t devtmpfs devtmpfs /dev      2>/dev/null || mount -t tmpfs tmpfs /dev 2>/dev/null || die "cannot mount /dev"

    mkdir -p /dev/pts /dev/shm
    mount -t devpts -o gid=5,mode=0620 devpts /dev/pts 2>/dev/null || true

    mount -t tmpfs -o size=64M,mode=0755 tmpfs /run 2>/dev/null || die "cannot mount /run"
    mkdir -p /tmp
    mount -t tmpfs -o size=16M tmpfs /tmp 2>/dev/null || true

    # Verify features
    for f in loop squashfs overlay; do
        if ! grep -q "$f" /proc/filesystems /proc/devices 2>/dev/null; then
            modprobe "$f" 2>/dev/null || true
            grep -q "$f" /proc/filesystems /proc/devices 2>/dev/null || warn "Kernel may lack support for: $f"
        fi
    done
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 1 — LOCATE BOOT DEVICE
#───────────────────────────────────────────────────────────────────────────────

_parse_cmdline() {
    local param
    for param in $(cat /proc/cmdline); do
        case "$param" in
            frugal.dev=*)   BOOT_DEV="${param#frugal.dev=}"     ;;
            frugal.uuid=*)  BOOT_UUID="${param#frugal.uuid=}"   ;;
            frugal.label=*) BOOT_LABEL="${param#frugal.label=}" ;;
            frugal.save=*)  SAVE_DIR="${param#frugal.save=}"    ;;
            frugal.init=*)  INIT_BIN="${param#frugal.init=}"    ;;
            frugal.debug=1) DEBUG=1                              ;;
        esac
    done
}

_find_boot_device() {
    if [ -n "$BOOT_DEV" ] && [ -b "$BOOT_DEV" ]; then
        return 0
    fi

    # Wait for block devices
    local i=0
    while [ $i -lt 10 ]; do
        [ -d /sys/block ] && [ "$(ls /sys/block | wc -l)" -gt 0 ] && break
        sleep 1
        i=$((i + 1))
    done

    if [ -n "$BOOT_UUID" ]; then
        BOOT_DEV=$(blkid -U "$BOOT_UUID" 2>/dev/null || true)
        [ -n "$BOOT_DEV" ] && return 0
    fi

    # Label scan
    BOOT_DEV=$(blkid -L "$BOOT_LABEL" 2>/dev/null || true)
    if [ -z "$BOOT_DEV" ]; then
        # Fallback manual scan
        BOOT_DEV=$(blkid 2>/dev/null | grep "LABEL=\"$BOOT_LABEL\"" | head -n1 | cut -d: -f1)
    fi

    [ -n "$BOOT_DEV" ] || die "boot device (LABEL=$BOOT_LABEL) not found"
}

stage1_locate_boot() {
    log "Stage 1: locating boot device"
    _parse_cmdline
    _find_boot_device

    mkdir -p "$BOOT_MOUNT"
    mount -o ro "$BOOT_DEV" "$BOOT_MOUNT" || die "failed to mount $BOOT_DEV"
    [ -f "${BOOT_MOUNT}/os/base.sfs" ] || die "base.sfs not found on boot device"
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 2 — LOAD ORDER
#───────────────────────────────────────────────────────────────────────────────

_probe_load_order() {
    local sfs="$1"
    local mnt loop order
    mnt=$(mktemp -d /tmp/probe.XXXXXX)
    loop=$(losetup -f)
    losetup -r "$loop" "$sfs"
    if mount -t squashfs -o ro "$loop" "$mnt" 2>/dev/null; then
        if [ -f "$mnt/.plugin/manifest" ]; then
            order=$(grep "^LOAD_ORDER=" "$mnt/.plugin/manifest" | cut -d= -f2 | tr -d '"')
        fi
        umount "$mnt"
    fi
    losetup -d "$loop"
    rmdir "$mnt"
    printf '%s' "${order:-50}"
}

stage2_discover_plugins() {
    log "Stage 2: resolving layers"
    local sort_in="/run/_sort_in"
    : > "$sort_in"

    # base=0
    printf '0|%s/os/base.sfs\n' "$BOOT_MOUNT" >> "$sort_in"

    if [ -d "$BOOT_MOUNT/plugins/enabled" ]; then
        for sfs in "$BOOT_MOUNT/plugins/enabled"/*.sfs; do
            [ -f "$sfs" ] || continue
            order=$(_probe_load_order "$sfs")
            printf '%s|%s\n' "$order" "$sfs" >> "$sort_in"
        done
    fi

    sort -t'|' -k1 -n "$sort_in" | cut -d'|' -f2 > "$_ORDERED_SFS_FILE"
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 3 — MOUNT LAYERS
#───────────────────────────────────────────────────────────────────────────────

stage3_mount_layers() {
    log "Stage 3: mounting layers"
    mkdir -p "$LAYERS_BASE" "$PLUGIN_LOOPS_DIR" "$PLUGIN_STATE_DIR"
    : > "$_MOUNTPOINTS_FILE"
    : > "$_LOOP_RECORDS_FILE"

    local idx=0
    while read -r sfs; do
        local name=$(basename "$sfs" .sfs)
        local mnt="$LAYERS_BASE/${idx}_${name}"
        mkdir -p "$mnt"
        local loop=$(losetup -f)
        losetup -r "$loop" "$sfs"
        mount -t squashfs -o ro "$loop" "$mnt"

        printf '%s\n' "$mnt" >> "$_MOUNTPOINTS_FILE"
        printf '%s|%s|%s\n' "$name" "$loop" "$mnt" >> "$_LOOP_RECORDS_FILE"
        idx=$((idx + 1))
    done < "$_ORDERED_SFS_FILE"
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 4 — OVERLAY
#───────────────────────────────────────────────────────────────────────────────

stage4_mount_overlay() {
    log "Stage 4: mounting OverlayFS"
    local lowerdir=""
    while read -r mnt; do
        if [ -z "$lowerdir" ]; then lowerdir="$mnt"; else lowerdir="$mnt:$lowerdir"; fi
    done < "$_MOUNTPOINTS_FILE"

    local save_base="$BOOT_MOUNT/$SAVE_DIR"
    if mount -o remount,rw "$BOOT_DEV" "$BOOT_MOUNT" 2>/dev/null; then
        mkdir -p "$save_base/upper" "$save_base/work"
        UPPER_DIR="$save_base/upper"
        WORK_DIR="$save_base/work"
    else
        warn "boot device read-only, using tmpfs for save layer"
        mount -t tmpfs tmpfs /mnt -o size=128M
        mkdir -p /mnt/upper /mnt/work
        UPPER_DIR="/mnt/upper"
        WORK_DIR="/mnt/work"
    fi

    mkdir -p "$NEWROOT"
    mount -t overlay overlay -o "lowerdir=$lowerdir,upperdir=$UPPER_DIR,workdir=$WORK_DIR" "$NEWROOT"
}

#───────────────────────────────────────────────────────────────────────────────
# STAGE 5 — PIVOT
#───────────────────────────────────────────────────────────────────────────────

stage5_pivot() {
    log "Stage 5: pivot_root"
    mkdir -p "$NEWROOT/run/plugin-state"
    cp "$_LOOP_RECORDS_FILE" "$NEWROOT/run/plugin-state/active.list"
    {
        printf 'UPPER_DIR=%s\n' "$UPPER_DIR"
        printf 'WORK_DIR=%s\n'  "$WORK_DIR"
        printf 'BOOT_DEV=%s\n'  "$BOOT_DEV"
        printf 'BOOT_MOUNT=/mnt/boot\n'
    } > "$NEWROOT/run/plugin-state/overlay.env"

    for fs in /proc /sys /dev /run; do
        mkdir -p "$NEWROOT$fs"
        mount --move "$fs" "$NEWROOT$fs"
    done

    mkdir -p "$NEWROOT/mnt/boot"
    mount --move "$BOOT_MOUNT" "$NEWROOT/mnt/boot"

    cd "$NEWROOT"
    mkdir -p .initrd
    pivot_root . .initrd
    exec chroot . "$INIT_BIN" </dev/console >/dev/console 2>&1
}

#───────────────────────────────────────────────────────────────────────────────
# MAIN
#───────────────────────────────────────────────────────────────────────────────

stage0_early_mounts
stage1_locate_boot
stage2_discover_plugins
stage3_mount_layers
stage4_mount_overlay
stage5_pivot

die "reached end of /init"
