#!/bin/sh
#═══════════════════════════════════════════════════════════════════════════════
#  /usr/bin/plugin-ctl — FrugalOS Plugin Manager
#  Runtime  : busybox ash
#  Requires : losetup, mount, umount, mksquashfs, fuser
#═══════════════════════════════════════════════════════════════════════════════

set -eu
PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

PLUGIN_STATE="/run/plugin-state"
PLUGIN_LOOPS="/run/plugin-loops"
HOTLOAD_WORK="/run/hotload-work"
ACTIVE_LIST="${PLUGIN_STATE}/active.list"
HOTLOAD_ORDER="${PLUGIN_STATE}/hotload-order"

# Directories inside a .sfs that we consider for overmounting.
STD_DIRS="usr/lib usr/lib64 usr/libexec usr/include usr/share usr/bin usr/sbin etc opt"

#───────────────────────────────────────────────────────────────────────────────
# LOGGING
#───────────────────────────────────────────────────────────────────────────────

log()  { printf '\033[1;32m=>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m  warn:\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31m  error:\033[0m %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }

#───────────────────────────────────────────────────────────────────────────────
# HELPERS
#───────────────────────────────────────────────────────────────────────────────

_load_env() {
    local env_file="${PLUGIN_STATE}/overlay.env"
    [ -f "$env_file" ] || die "overlay.env missing — was this system booted with FrugalOS?"
    . "$env_file"
    PLUGINS_ENABLED="${BOOT_MOUNT}/plugins/enabled"
    PLUGINS_AVAILABLE="${BOOT_MOUNT}/plugins/available"
}

_require_root() {
    [ "$(id -u)" = "0" ] || die "operation requires root"
}

_resolve_sfs() {
    local name="${1%.sfs}"
    local sfs="${PLUGINS_AVAILABLE}/${name}.sfs"
    [ -f "$sfs" ] && { printf '%s' "$sfs"; return 0; }
    sfs="${PLUGINS_ENABLED}/${name}.sfs"
    [ -f "$sfs" ] && { printf '%s' "$sfs"; return 0; }
    return 1
}

_is_active() {
    grep -q "^${1%.sfs}|" "$ACTIVE_LIST" 2>/dev/null
}

_get_mountpoint() {
    grep "^${1%.sfs}|" "$ACTIVE_LIST" 2>/dev/null | cut -d'|' -f3
}

_get_loopdev() {
    grep "^${1%.sfs}|" "$ACTIVE_LIST" 2>/dev/null | cut -d'|' -f2
}

#───────────────────────────────────────────────────────────────────────────────
# COMMANDS
#───────────────────────────────────────────────────────────────────────────────

cmd_load() {
    local name="${1%.sfs}"
    [ -n "$name" ] || die "usage: plugin-ctl load <name>"
    _is_active "$name" && die "'$name' is already active"

    local sfs
    sfs=$(_resolve_sfs "$name") || die "plugin '$name' not found"

    log "loading plugin: $name"

    local loop=$(losetup -f)
    local mnt="${PLUGIN_LOOPS}/${name}"
    mkdir -p "$mnt"
    losetup -r "$loop" "$sfs"
    mount -t squashfs -o ro "$loop" "$mnt"

    # Overmount dirs
    local overmount_record="${PLUGIN_STATE}/overmounts/${name}"
    mkdir -p "$(dirname "$overmount_record")"
    : > "$overmount_record"

    for d in $STD_DIRS; do
        [ -d "$mnt/$d" ] || continue
        local abs_d="/$d"
        mkdir -p "$abs_d"
        local safe_d=$(echo "$d" | tr '/' '_')
        local upper="${HOTLOAD_WORK}/${name}/${safe_d}/upper"
        local work="${HOTLOAD_WORK}/${name}/${safe_d}/work"
        mkdir -p "$upper" "$work"

        mount -t overlay "overlay_$name" -o "lowerdir=$mnt/$d:$abs_d,upperdir=$upper,workdir=$work" "$abs_d"
        printf '%s\n' "$abs_d" >> "$overmount_record"
    done

    # Run hook
    if [ -x "$mnt/.plugin/on_load" ]; then
        "$mnt/.plugin/on_load" || warn "on_load hook failed"
    fi

    printf '%s|%s|%s|hot\n' "$name" "$loop" "$mnt" >> "$ACTIVE_LIST"
    printf '%s\n' "$name" >> "$HOTLOAD_ORDER"
}

cmd_unload() {
    local name="${1%.sfs}"
    [ -n "$name" ] || die "usage: plugin-ctl unload <name>"
    _is_active "$name" || die "'$name' is not active"

    # LIFO enforcement
    local top=$(tail -n1 "$HOTLOAD_ORDER" 2>/dev/null || true)
    [ "$top" = "$name" ] || die "LIFO violation: must unload '$top' first"

    log "unloading plugin: $name"
    local mnt=$(_get_mountpoint "$name")
    local loop=$(_get_loopdev "$name")

    if [ -x "$mnt/.plugin/on_unload" ]; then
        "$mnt/.plugin/on_unload" || warn "on_unload hook failed"
    fi

    local overmount_record="${PLUGIN_STATE}/overmounts/${name}"
    if [ -f "$overmount_record" ]; then
        # Unmount in reverse order
        local dirs=$(tail -r "$overmount_record" 2>/dev/null || awk '{a[i++]=$0} END {for (j=i-1; j>=0; j--) print a[j]}' "$overmount_record")
        for d in $dirs; do
            if fuser -s "$d" 2>/dev/null; then
                die "directory $d is busy"
            fi
            umount "$d"
        done
        rm "$overmount_record"
    fi

    umount "$mnt"
    losetup -d "$loop"
    rmdir "$mnt"

    # Remove from tracking files
    local tmp=$(mktemp)
    grep -v "^$name|" "$ACTIVE_LIST" > "$tmp" || true
    mv "$tmp" "$ACTIVE_LIST"

    head -n -1 "$HOTLOAD_ORDER" > "$tmp" || true
    mv "$tmp" "$HOTLOAD_ORDER"
}

cmd_list() {
    log "Active Plugins:"
    [ -f "$ACTIVE_LIST" ] && column -t -s '|' "$ACTIVE_LIST" || echo "  (none)"

    log "Available Plugins:"
    ls "$PLUGINS_AVAILABLE" 2>/dev/null | sed 's/\.sfs$//' | sed 's/^/  /'
}

#───────────────────────────────────────────────────────────────────────────────
# MAIN
#───────────────────────────────────────────────────────────────────────────────

[ $# -gt 0 ] || die "usage: plugin-ctl <command> [args]"
_load_env
_require_root

case "$1" in
    load)   cmd_load   "$2" ;;
    unload) cmd_unload "$2" ;;
    list)   cmd_list        ;;
    *)      die "unknown command: $1" ;;
esac
